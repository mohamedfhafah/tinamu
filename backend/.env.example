FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=change-me-with-at-least-32-characters

# Demo default: SQLite file created automatically next to the backend files
DATABASE_URL=sqlite:///tinamu.db

# Optional PostgreSQL override
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tinamu_db

# JWT
JWT_SECRET_KEY=change-me-with-at-least-32-characters

# CORS (frontend Vite)
CORS_ORIGINS=http://localhost:5173
